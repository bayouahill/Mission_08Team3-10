@model Mission_08Team3_10.Models.Task

@{
    ViewData["Title"] = "Edit Task";
}

<div class="container">
    <div class="row justify-content-center mt-4">
        <div class="col-lg-8">
            <div class="page-card p-4">
                <h1 class="mb-4 fs-3">Edit Task</h1>

                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="TaskId" />

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <partial name="~/Views/Shared/TaskForm.cshtml" model="Model" />

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-primary px-4" type="submit">Save Changes</button>
                        <a class="btn btn-outline-secondary" asp-action="Quadrants">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}