@model IEnumerable<Mission_08Team3_10.Models.Task>

@{
    ViewData["Title"] = "Quadrants";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Task Quadrants</h1>
    <a asp-action="Create" class="btn btn-primary">+ Add Task</a>
</div>

<div class="row g-4">
    <!-- Quadrant I -->
    <div class="col-md-6">
        <div class="quadrant-card">
            <div class="quadrant-header q1">Quadrant I &mdash; Important / Urgent</div>
            @{var q1 = Model.Where(x => x.Quadrant == 1).ToList();}
            @if (!q1.Any())
            {
                <div class="empty-quadrant">No tasks here</div>
            }
            @foreach (var t in q1)
            {
                <div class="task-item">
                    <div class="task-info">
                        <div class="task-name">@t.TaskName</div>
                        <div class="task-meta">
                            @if (t.DueDate.HasValue) { <span>Due: @t.DueDate.Value.ToShortDateString() &nbsp;</span> }
                            @if (t.Category != null) { <span>@t.Category.CategoryName</span> }
                        </div>
                    </div>
                    <div class="task-actions">
                        <a asp-action="Edit" asp-route-id="@t.TaskId" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@t.TaskId" class="btn btn-sm btn-outline-danger">Delete</a>
                        <a asp-action="Complete" asp-route-id="@t.TaskId" class="btn btn-sm btn-success">Done</a>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Quadrant II -->
