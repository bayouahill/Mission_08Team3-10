@* Delete confirmation view - shows task details before user confirms deletion *@
@model Mission_08Team3_10.Models.Task
@{
    ViewData["Title"] = "Delete Task";
}

<div class="row">
    <div class="col-lg-8">
        <h1 class="mb-3">Delete Task</h1>
        <p class="text-danger">Are you sure you want to delete this task?</p>

        @* Definition list - displays task properties so user knows what they're deleting *@
        <dl class="row">
            <dt class="col-sm-3">Task</dt>
            <dd class="col-sm-9">@Model.TaskName</dd>

            <dt class="col-sm-3">Due Date</dt>
            <dd class="col-sm-9">@Model.DueDate?.ToShortDateString()</dd>

            <dt class="col-sm-3">Quadrant</dt>
            <dd class="col-sm-9">@Model.Quadrant</dd>

            <dt class="col-sm-3">Category</dt>
            <dd class="col-sm-9">@Model.Category?.CategoryName</dd>
        </dl>

        @* Form POSTs to Delete action - id comes from route *@
        <form method="post" asp-action="Delete" asp-route-id="@Model.TaskId">
            <input type="hidden" asp-for="TaskId" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a class="btn btn-outline-secondary" asp-action="Quadrants">Cancel</a>
        </form>
    </div>
</div>
